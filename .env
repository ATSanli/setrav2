# Copy this file to .env and fill in real values

# For MySQL (example):
# DATABASE_URL="mysql://

# For SQLite (development quick start):
# DATABASE_URL="postgresql:
# DATABASE_URL="postgresql://
# Secret used by next-auth (set to a secure random value in production)
# NEXTAUTH_SECRET="

# Optional: set NEXTAUTH_URL if using different host/port
# NEXTAUTH_URL="htt


# CLOUDINARY_CLOUD_NAME=xxx
# CLOUDINARY_API_KEY=xxx
# CLOUDINARY_API_SECRET=xxx